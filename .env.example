# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# LLM tier models (defaults to Anthropic Claude)
# LLM_PROVIDER=anthropic
# LLM_QUICK_MODEL=claude-haiku-4-5-20251001
# LLM_DEEP_MODEL=claude-sonnet-4-6

# Ollama (local LLM — free alternative to Anthropic)
# Requires: ollama pull llama3.2:3b && ollama pull llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LLM_PROVIDER=ollama
# LLM_QUICK_MODEL=llama3.2:3b
# LLM_DEEP_MODEL=llama3.1:8b
CLAUDE_MODEL=claude-sonnet-4-6

# Alpaca Markets (paper trading)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# News provider keys
BENZINGA_API_KEY=...
POLYGON_API_KEY=...

# Redis
REDIS_URL=redis://localhost:6379/0

# Database
DATABASE_URL=sqlite:///data/trades.db

# Trading parameters
WATCHLIST=["AAPL","MSFT","GOOGL","AMZN","TSLA"]
NEWS_POLL_INTERVAL_SEC=30
MAX_POSITION_PCT=0.05
MAX_TOTAL_POSITIONS=10
MAX_DRAWDOWN_PCT=0.03
MIN_SIGNAL_CONVICTION=0.6

# Provider selection (defaults to free-tier stack)
NEWS_PROVIDER=rss
MARKET_DATA_PROVIDER=yfinance
SENTIMENT_PROVIDER=claude

# Cost controls
CLAUDE_DAILY_BUDGET_USD=2.00
SENTIMENT_DRY_RUN=false
NEWS_KEYWORD_PREFILTER=true

# PEAD horizon (calendar days after EARN_BEAT/MISS fill before auto-close)
PEAD_HORIZON_DAYS=5

# Telegram Bot (optional — leave blank to disable)
# Get a token from @BotFather and your chat ID from @userinfobot
# TELEGRAM_BOT_TOKEN=123456789:AAF...
# TELEGRAM_CHAT_ID=987654321
# Set to true to require Telegram approval before each signal executes
# TELEGRAM_SIGNAL_APPROVAL=false
# TELEGRAM_APPROVAL_TIMEOUT_SEC=30
